{
  "profiles": {
    "Docker Compose": {
      "commandName": "DockerCompose",
      "commandVersion": "1.0",
      "composeLaunchAction": "LaunchBrowser",
      "composeLaunchServiceName": "yourfilms.api",
      "composeLaunchUrl": "{Scheme}://localhost:{ServicePort}/swagger",
      "serviceActions": {
        "yourfilms.api": "StartDebugging",
        "yourfilms.cache": "DoNotStart",
        "yourfilms.db": "DoNotStart"
      }
    }
  }
}